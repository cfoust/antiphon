/scratch
/target
/out*
# raw upstream HRTF/BRIR downloads (fetched, not committed)
/assets/sofa
# measured-SOFA bakes are regenerable from assets/sofa; only the analytic default is committed
/assets/baked/*
!/assets/baked/chamber-default.chamber
# web app: deps, build output, staged engine artifacts (produced by tools/build-web.sh)
/web/node_modules
/web/dist
/web/.wrangler
/web/.env
/web/public/chamber_ffi.wasm
/web/public/chamber.chamber
# native build output
*.app
.DS_Store
# marketing-site design handoff (local reference, not part of the repo)
/design_handoff_antiphon_site
/handoff.zip
# Claude Code session data + agent worktrees
/.claude
*.mov
