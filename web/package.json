{
  "name": "agent-chamber",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spatial-audio voice interface prototype for monitoring AI coding agents",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler pages deploy dist --project-name agent-chamber --branch main --commit-dirty=true",
    "bridge": "bun run bridge/server.ts",
    "dev:live": "CHAMBER_LIVE=1 vite",
    "chamber-demo": "bun run bridge/mock.ts"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "0.10.14",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
