{
  "name": "agent-chamber",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Spatial-audio voice interface prototype for monitoring AI coding agents",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler pages deploy dist --project-name agent-chamber --branch main --commit-dirty=true"
  },
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/gfs-didot": "^5.2.8",
    "@fontsource/instrument-sans": "^5.2.8",
    "@mediapipe/tasks-vision": "0.10.14",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/three": "^0.185.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
