# Agent Antiphon — spatial voice prototype (Bun + Vite + TypeScript)

# List recipes
default:
    @just --list

# Install JS dependencies
install:
    bun install

# Build the Rust wasm engine + stage the HRTF asset into public/ (run after engine changes)
wasm:
    bash ../tools/build-web.sh

# Run the Vite dev server over HTTPS (exposed on LAN for on-device testing).
# On your phone, open the https://<your-ip>:5173 URL it prints and accept the cert.
dev: wasm
    bun run dev

# Sandbox — THE dev tool (replaces the old harness/arp-lab/attention-demo pages): a 3D
# scene editor over the real engine. Place/drag/aim sources (directivity + extent), loop
# SFX/voices/ARPs/audio files, room + reverb controls, head tracking, immersion toggle.
# Plain HTTP on :5174 (localhost is a secure context, so the camera still works).
sandbox: wasm
    ANTIPHON_HTTP=1 bun run dev --port 5174 --strictPort --open /sandbox.html

# Back-compat alias for muscle memory.
harness: sandbox

# Type-check and build to dist/
build: wasm
    bun run build

# Preview the production build
preview:
    bun run preview

# Deploys ship via GitHub Pages (.github/workflows/site.yml) on push to main.

# --- live mode: monitor a real local Claude Code session by ear ----------------
# antiphond (the Go daemon) is the hub now — the app or `antiphond serve` runs it.
# The page connects to ws://127.0.0.1:8787/stream.

# The page in LIVE mode (plain http on localhost so camera + ws coexist).
# Then open http://localhost:5173/demo.html?live and run through onboarding.
dev-live:
    ANTIPHON_LIVE=1 bun run dev
