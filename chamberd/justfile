# chamberd — the Chamber agent bridge daemon (see ../docs/agent-bridge.md)

default:
    @just --list

# Build the daemon to bin/chamberd (the cc-chamber launcher looks here).
build:
    go build -o bin/chamberd ./cmd/chamberd

test:
    go test ./...

vet:
    go vet ./...

# Run the hub on 127.0.0.1:8787 (CHAMBER_PORT / ELEVENLABS_API_KEY respected).
serve: build
    ./bin/chamberd serve
