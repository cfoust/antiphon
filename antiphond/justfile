# antiphond — the Antiphon agent bridge daemon (protocol: ../plugins/README.md)

default:
    @just --list

# Build the daemon to bin/antiphond (the claude-code plugin launcher looks here).
build:
    go build -o bin/antiphond ./cmd/antiphond

test:
    go test ./...

vet:
    go vet ./...

# Run the hub on 127.0.0.1:8787 (ANTIPHON_PORT respected; API keys come from Settings).
serve: build
    ./bin/antiphond serve
